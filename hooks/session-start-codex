#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

escape_for_json() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

using_dev_cadence_content=$(cat "${PLUGIN_ROOT}/skills/using-dev-cadence/SKILL.md" 2>&1 || echo "Error reading using-dev-cadence skill")
using_dev_cadence_escaped=$(escape_for_json "$using_dev_cadence_content")

session_context="<EXTREMELY_IMPORTANT>\nYou have dev-cadence.\n\nBelow is the full content of your 'using-dev-cadence' bootstrap skill. Use it to route delivery tasks through Dev Cadence workflow, Harness evidence, Quality Gates, Human Gates, and the applicable cadence-* discipline Skills. For all other Dev Cadence Skills, follow Codex native skill-loading behavior when they apply.\n\n${using_dev_cadence_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
